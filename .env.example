# Polymarket Configuration
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2

# Telegram Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Configuration
TRADE_AMOUNT_USDC=1.0

# Database (optional - defaults to autopoly.db)
DB_PATH=autopoly.db

# Polygon RPC (for direct on-chain redemption via web3.py)
# Use a reliable provider like Alchemy or Infura for production
# Public fallback (https://polygon-rpc.com) is used if this is not set
POLYGON_RPC_URL=https://polygon-rpc.com

# Auto-Redeem Configuration (optional - these are the defaults)
# How often (in minutes) the scheduler scans for redeemable positions
AUTO_REDEEM_INTERVAL_MINUTES=30
# Maximum gas price in gwei - redemption is skipped if Polygon gas exceeds this
AUTO_REDEEM_MAX_GAS_GWEI=100
